local function updateCoords()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local p = hrp.Position

    valX.Text = string.format("%.2f", p.X)
    valY.Text = string.format("%.2f", p.Y)
    valZ.Text = string.format("%.2f", p.Z)
    vecLabel.Text = string.format("Vector3.new(%.2f, %.2f, %.2f)", p.X, p.Y, p.Z)

    showToast("Координаты", string.format("X %.0f  Y %.0f  Z %.0f", p.X, p.Y, p.Z), C.accent)

    tween(coordCard, {BackgroundColor3 = Color3.fromRGB(24, 30, 56)}, 0.1)
    task.delay(0.3, function() tween(coordCard, {BackgroundColor3 = C.surface}, 0.3) end)
end

