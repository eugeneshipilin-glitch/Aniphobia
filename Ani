local function setFullbright(state, label, btn, st)
    fullbrightEnabled = state
    if state then
        -- FIX: устанавливаем значения напрямую без tween для Lighting
        Lighting.Ambient        = Color3.fromRGB(178, 178, 178)
        Lighting.Brightness     = 2
        Lighting.OutdoorAmbient = Color3.fromRGB(178, 178, 178)
        -- Убираем атмосферу и туман если есть
        local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmosphere then atmosphere.Density = 0 end
        tween(btn, {BackgroundColor3 = Color3.fromRGB(60, 50, 10)}, 0.15)
        tween(st,  {Color = C.orange}, 0.15)
        label.Text       = "☀  Fullbright  ON"
        label.TextColor3 = C.orange
    else
        -- FIX: восстанавливаем оригинальные значения
        if origAmbient then
            Lighting.Ambient        = origAmbient
            Lighting.Brightness     = origBrightness
            Lighting.OutdoorAmbient = origOutdoorAmbient
        end
        local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmosphere then atmosphere.Density = nil end  -- сбросит на дефолт
        tween(btn, {BackgroundColor3 = C.accentDim}, 0.15)
        tween(st,  {Color = C.accent}, 0.15)
        label.Text       = "☀  Fullbright  OFF"
        label.TextColor3 = C.accent
    end
end

