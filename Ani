local pages = {page1, page2, page3}
local tabAccents = {C.accent, C.accent, C.success}

local function switchTab(idx)
    if idx == activeTab then return end
    pages[activeTab].Visible = false
    tween(tabBtns[activeTab].btn,   {BackgroundTransparency = 1}, 0.18)
    tween(tabBtns[activeTab].label, {TextColor3 = C.textDim}, 0.18)

    activeTab = idx
    pages[activeTab].Visible = true
    tween(tabBtns[activeTab].btn,   {BackgroundColor3 = tabAccents[activeTab], BackgroundTransparency = 0}, 0.18)
    tween(tabBtns[activeTab].label, {TextColor3 = C.white}, 0.18)
end

