--  TOAST  (FIX: длительность 1.5с вместо 2.8с)
-- ══════════════════════════════════════════

local TOAST_DURATION = 1.5   -- было 2.8

local toastQueue = {}
local toastActive = false

local function showToast(title, message, accent)
    accent = accent or C.accent
    table.insert(toastQueue, {title=title, message=message, accent=accent})
    if toastActive then return end
    toastActive = true

    local function processNext()
        if #toastQueue == 0 then toastActive = false return end
        local data = table.remove(toastQueue, 1)

        local toast = newFrame(sg, {
            Size = UDim2.fromOffset(300, 62),
            Position = UDim2.new(1, 20, 1, -90),
            AnchorPoint = Vector2.new(1, 1),
            BackgroundColor3 = C.surfaceHigh,
            ZIndex = 200,
        })
        corner(toast, 10)
        stroke(toast, data.accent, 1.5)

        local bar = newFrame(toast, {
            Size = UDim2.fromOffset(3, 18),
            Position = UDim2.fromOffset(8, 8),
            BackgroundColor3 = data.accent,
            ZIndex = 201,
        })
        corner(bar, 4)

        newLabel(toast, {
            Size = UDim2.new(1, -26, 0, 20),
            Position = UDim2.fromOffset(20, 8),
            Text = data.title,
            TextColor3 = data.accent,
            TextSize = 12,
            ZIndex = 201,
        })
        newLabel(toast, {
            Size = UDim2.new(1, -26, 0, 18),
            Position = UDim2.fromOffset(20, 28),
            Text = data.message,
            TextColor3 = C.text,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            ZIndex = 201,
        })

        local prog = newFrame(toast, {
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BackgroundColor3 = data.accent,
            ZIndex = 202,
        })
        corner(prog, 2)

        tween(toast, {Position = UDim2.new(1, -16, 1, -90)}, 0.35, Enum.EasingStyle.Back)
        TweenService:Create(prog, TweenInfo.new(TOAST_DURATION, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)}):Play()

        task.delay(TOAST_DURATION, function()
            tween(toast, {Position = UDim2.new(1, 340, 1, -90)}, 0.3)
            task.delay(0.35, function()
                toast:Destroy()
                processNext()
            end)
        end)
    end

    processNext()
end

