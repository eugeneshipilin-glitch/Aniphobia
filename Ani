local function tween(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    TweenService:Create(obj, TweenInfo.new(t or 0.25, style, dir), props):Play()
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or C.border
    s.Thickness = thickness or 1
    s.Transparency = 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function newFrame(parent, props)
    local f = Instance.new("Frame")
    f.BorderSizePixel = 0
    f.BackgroundColor3 = C.surface
    for k, v in pairs(props or {}) do f[k] = v end
    f.Parent = parent
    return f
end

local function newLabel(parent, props)
    local l = Instance.new("TextLabel")
    l.BorderSizePixel = 0
    l.BackgroundTransparency = 1
    l.TextColor3 = C.text
    l.Font = Enum.Font.GothamBold
    l.TextSize = 13
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    for k, v in pairs(props or {}) do l[k] = v end
    l.Parent = parent
    return l
end

local function newButton(parent, props)
    local b = Instance.new("TextButton")
    b.BorderSizePixel = 0
    b.AutoButtonColor = false
    b.TextColor3 = C.text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 13
    b.Text = ""
    for k, v in pairs(props or {}) do b[k] = v end
    b.Parent = parent
    return b
end

local function ripple(btn, accent)
    accent = accent or C.accent
    local rip = Instance.new("Frame")
    rip.Size = UDim2.fromOffset(0, 0)
    rip.AnchorPoint = Vector2.new(0.5, 0.5)
    rip.Position = UDim2.fromScale(0.5, 0.5)
    rip.BackgroundColor3 = accent
    rip.BackgroundTransparency = 0.65
    rip.BorderSizePixel = 0
    rip.ZIndex = btn.ZIndex + 10
    corner(rip, 999)
    rip.Parent = btn
    TweenService:Create(rip, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.fromOffset(btn.AbsoluteSize.X * 2.5, btn.AbsoluteSize.X * 2.5),
        BackgroundTransparency = 1,
    }):Play()
    task.delay(0.5, function() rip:Destroy() end)
end

