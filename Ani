UserInputService.InputBegan:Connect(function(input, gp)
    if bindListening then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            bindListening = false
            flyBindKey = input.KeyCode
            bindLabel.Text = flyBindKey.Name
            bindLabel.TextColor3 = C.success
            tween(bindStroke, {Color = C.success}, 0.1)
            showToast("Бинд", "Бинд полёта: " .. flyBindKey.Name, C.success)
        end
        return
    end

    if gp then return end

    if input.KeyCode == Enum.KeyCode.F then
        updateCoords()

    elseif input.KeyCode == flyBindKey then
        flyEnabled = not flyEnabled
        flyUpdatePill(flyEnabled)
        if flyEnabled then
            startFly()
            flyToggleLabel.Text = "✈  Полёт  ON"
            flyToggleLabel.TextColor3 = C.success
            tween(flyToggleStroke, {Color = C.success}, 0.15)
            showToast("Помощь", "✈  Полёт включён [" .. flyBindKey.Name .. "]", C.success)
        else
            stopFly()
            flyToggleLabel.Text = "✈  Полёт  OFF"
            flyToggleLabel.TextColor3 = C.accent
            tween(flyToggleStroke, {Color = C.accent}, 0.15)
            showToast("Помощь", "✈  Полёт выключен", C.accent)
        end

    elseif input.KeyCode == Enum.KeyCode.RightShift then
        isHidden = not isHidden
        if isHidden then
            tween(win,    {BackgroundTransparency = 1}, 0.2)
            tween(shadow, {BackgroundTransparency = 1}, 0.2)
            task.delay(0.22, function()
                container.Visible = false
            end)
        else
            container.Visible = true
            win.BackgroundTransparency = 1
            shadow.BackgroundTransparency = 1
            tween(win,    {BackgroundTransparency = 0}, 0.25, Enum.EasingStyle.Quart)
            tween(shadow, {BackgroundTransparency = 0.45}, 0.25)
        end
    end
end)

player.CharacterRemoving:Connect(function()
    if flyEnabled then
