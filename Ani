local function setNoclip(state, label, btn, st)
    noclipEnabled = state
    local ncColor = Color3.fromRGB(255, 120, 200)
    if state then
        tween(btn, {BackgroundColor3 = Color3.fromRGB(60, 20, 50)}, 0.15)
        tween(st,  {Color = ncColor}, 0.15)
        label.Text       = "👻  NoClip  ON"
        label.TextColor3 = ncColor

        noclipConn = RunService.Stepped:Connect(function()
            local char = player.Character
            if not char then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end)
    else
        if noclipConn then noclipConn:Disconnect() noclipConn = nil end
        local char = player.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        tween(btn, {BackgroundColor3 = C.accentDim}, 0.15)
        tween(st,  {Color = C.accent}, 0.15)
        label.Text       = "👻  NoClip  OFF"
        label.TextColor3 = C.accent
    end
end

